<?xml version="1.0" encoding="utf-8"?>

<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="http://www.nlog-project.org/schemas/NLog.xsd NLog.xsd"
      throwConfigExceptions="true"
      internalLogLevel="Off">

    <!-- 时间 | 级别 | 线程 | 调用处 | 消息；caller 由 NLog.cs 在记录时写入 event-properties -->
    <variable name="defaultLayout"
              value="${longdate} | ${level:uppercase=true:padding=-5} | T${threadid:padding=3} | ${event-properties:item=caller:whenEmpty=?} | ${message}${onexception:inner=${newline}${exception:format=tostring}}" />

    <!-- ANSI 序列由 NLog.cs Initialize 注入到 var:ansiSoftWhite / var:ansiReset（XML 不能含 0x1B） -->
    <variable name="consoleLayout"
              value="${when:when=level==LogLevel.Info:inner=${var:ansiSoftWhite}}${defaultLayout}${when:when=level==LogLevel.Info:inner=${var:ansiReset}}" />

    <targets async="true">
        <target name="ServerDebug" xsi:type="File"
                encoding="UTF-8"
                createDirs="true"
                autoFlush="false"
                keepFileOpen="true"
                concurrentWrites="true"
                openFileCacheTimeout="30"
                openFileFlushTimeout="60"
                fileName="${basedir}/../Logs/Server/${date:format=yyyyMMdd}/${var:appId}/${event-properties:item=sceneName}.${var:appId}.${date:format=yyyyMMddHH}.Debug.log"
                layout="${defaultLayout}" />
    </targets>
    <targets async="true">
        <target name="ServerInfo" xsi:type="File"
                encoding="UTF-8"
                createDirs="true"
                autoFlush="false"
                keepFileOpen="true"
                concurrentWrites="true"
                openFileCacheTimeout="30"
                openFileFlushTimeout="60"
                fileName="${basedir}/../Logs/Server/${date:format=yyyyMMdd}/${var:appId}/${event-properties:item=sceneName}.${var:appId}.${date:format=yyyyMMddHH}.Info.log"
                layout="${defaultLayout}" />
    </targets>
    <targets async="true">
        <target name="ServerWarn" xsi:type="File"
                encoding="UTF-8"
                createDirs="true"
                autoFlush="false"
                keepFileOpen="true"
                concurrentWrites="true"
                openFileCacheTimeout="30"
                openFileFlushTimeout="60"
                fileName="${basedir}/../Logs/Server/${date:format=yyyyMMdd}/${var:appId}/${event-properties:item=sceneName}.${var:appId}.${date:format=yyyyMMddHH}.Warn.log"
                layout="${defaultLayout}" />
    </targets>
    <targets async="true">
        <target name="ServerError" xsi:type="File"
                encoding="UTF-8"
                createDirs="true"
                autoFlush="false"
                keepFileOpen="true"
                concurrentWrites="true"
                openFileCacheTimeout="30"
                openFileFlushTimeout="60"
                fileName="${basedir}/../Logs/Server/${date:format=yyyyMMdd}/${var:appId}/${event-properties:item=sceneName}.${var:appId}.${date:format=yyyyMMddHH}.Error.log"
                layout="${defaultLayout}" />
    </targets>
    <targets async="true">
        <target name="ServerTrace" xsi:type="File"
                encoding="UTF-8"
                createDirs="true"
                autoFlush="false"
                keepFileOpen="true"
                concurrentWrites="true"
                openFileCacheTimeout="30"
                openFileFlushTimeout="60"
                fileName="${basedir}/../Logs/Server/${date:format=yyyyMMdd}/${var:appId}/${event-properties:item=sceneName}.${var:appId}.${date:format=yyyyMMddHH}.Trace.log"
                layout="${defaultLayout}" />
    </targets>
    <targets async="true">
        <target name="ConsoleColor" xsi:type="ColoredConsole"
                useDefaultRowHighlightingRules="false"
                detectConsoleAvailable="true"
                enableAnsiOutput="true"
                layout="${consoleLayout}">
            <!-- INFO 由 consoleLayout 真彩控制；其余级别用 named color -->
            <highlight-row condition="level == LogLevel.Trace" foregroundColor="DarkGray" />
            <highlight-row condition="level == LogLevel.Debug" foregroundColor="DarkCyan" />
            <highlight-row condition="level == LogLevel.Warn"  foregroundColor="Yellow" />
            <highlight-row condition="level == LogLevel.Error" foregroundColor="Red" />
            <highlight-row condition="level == LogLevel.Fatal" foregroundColor="White" backgroundColor="DarkRed" />

            <highlight-word text="TRACE" foregroundColor="DarkGray" ignoreCase="true" wholeWords="true" />
            <highlight-word text="DEBUG" foregroundColor="Cyan" ignoreCase="true" wholeWords="true" />
            <highlight-word text="INFO"  foregroundColor="Green" ignoreCase="true" wholeWords="true" />
            <highlight-word text="WARN"  foregroundColor="Yellow" ignoreCase="true" wholeWords="true" />
            <highlight-word text="ERROR" foregroundColor="Red" ignoreCase="true" wholeWords="true" />
            <highlight-word text="FATAL" foregroundColor="Magenta" ignoreCase="true" wholeWords="true" />
        </target>
    </targets>
    <rules>
        <logger ruleName="ConsoleTrace" name="Server" level="Trace" writeTo="ConsoleColor" />
        <logger ruleName="ConsoleDebug" name="Server" level="Debug" writeTo="ConsoleColor" />
        <logger ruleName="ConsoleInfo"  name="Server" level="Info"  writeTo="ConsoleColor" />
        <logger ruleName="ConsoleWarn"  name="Server" level="Warn"  writeTo="ConsoleColor" />
        <logger ruleName="ConsoleError" name="Server" level="Error" writeTo="ConsoleColor" />
        <logger ruleName="ServerDebug" name="Server" level="Debug" writeTo="ServerDebug" />
        <logger ruleName="ServerTrace" name="Server" level="Trace" writeTo="ServerTrace" />
        <logger ruleName="ServerInfo"  name="Server" level="Info"  writeTo="ServerInfo" />
        <logger ruleName="ServerWarn"  name="Server" level="Warn"  writeTo="ServerWarn" />
        <logger ruleName="ServerError" name="Server" level="Error" writeTo="ServerError" />
    </rules>
</nlog>
